# ── Ollama (local LLM) ───────────────────────────────────────────────────────
# URL of your Ollama instance. Default works if Ollama is on the same machine.
OLLAMA_BASE_URL=http://localhost:11434

# Model to use for analysis generation. Must be pulled before running:
#   ollama pull llama3.1:8b
# Tested models: llama3.1:8b, mistral:7b, llama3.2:3b (faster, lower quality)
OLLAMA_MODEL=llama3.1:8b

# ── Telegram ─────────────────────────────────────────────────────────────────
# Create a bot via @BotFather and obtain the token.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Send a message to your bot, then call:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# and copy the chat id from the response.
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Logging ──────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
